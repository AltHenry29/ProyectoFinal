<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.LoginController"
      alignment="CENTER"
      spacing="15"
      stylesheets="@../css/estilos.css"
      styleClass="root">

   <padding>
      <Insets top="30" right="30" bottom="30" left="30"/>
   </padding>

   <Label
           text="Biblioteca Virtual"
           styleClass="titulo"/>

   <Label
           text="Sistema de Administración"
           styleClass="subtitulo"/>

   <Separator prefWidth="260"/>

   <Label text="Usuario"/>

   <TextField
           fx:id="user"
           promptText="Ingrese su usuario"
           prefWidth="250"/>

   <Label text="Contraseña"/>

   <PasswordField
           fx:id="pass"
           promptText="Ingrese su contraseña"
           prefWidth="250"/>

   <HBox alignment="CENTER" spacing="15">

      <Button
              text="Ingresar"
              onAction="#Confirmar"
              prefWidth="110"/>

      <Button
              text="Salir"
              onAction="#sal"
              prefWidth="110"
              styleClass="btnEliminar"/>

   </HBox>

</VBox>