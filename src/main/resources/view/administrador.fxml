<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane stylesheets="@../css/estilos.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AdministradorController">

    <top>
        <VBox alignment="CENTER" spacing="10" styleClass="panel">

            <Label styleClass="titulo" text="Biblioteca Virtual" />

            <Label styleClass="subtitulo" text="Panel de Administración" />

        </VBox>
    </top>

    <center>
        <VBox spacing="15">
            <padding>
                <Insets bottom="15" top="15" />
            </padding>
                <HBox spacing="10">
                    <TextField fx:id="txtBuscar" promptText="Buscar libro..." />
                    <Button onAction="#buscarLibro" text="Buscar" />
                </HBox>

            <TableView fx:id="tablaLibros">
                <columns>
                    <TableColumn fx:id="colId" text="ID" />
                    <TableColumn fx:id="colTitulo" text="Título" />
                    <TableColumn fx:id="colAutor" text="Autor" />
                    <TableColumn fx:id="colISBN" text="ISBN" />
                    <TableColumn fx:id="colAnio" text="Año" />
                    <TableColumn fx:id="colGenero" text="Género" />
                </columns>
            </TableView>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER" spacing="15" styleClass="panel">
            <Button onAction="#abrirEmpleado" text="Agregar" />
            <Button onAction="#editar" styleClass="btnEditar" text="Editar" />
            <Button onAction="#eliminar" styleClass="btnEliminar" text="Eliminar" />
            <Button onAction="#actualizar" styleClass="btnActualizar" text="Actualizar" />
            <Button onAction="#cerrarSesion" text="Cerrar Sesión" />
        </HBox>
    </bottom>
</BorderPane>
